---
type Row = {
	title: string;
	body: string;
};

type Props = {
	rows: Row[];
};

const { rows } = Astro.props;
---

<div class="rows">
	{
		rows.map((row) => (
			<article class="row">
				<h3>{row.title}</h3>
				<p>{row.body}</p>
			</article>
		))
	}
</div>

<style>
	.rows {
		border-top: 1px solid var(--line);
	}

	.row {
		display: grid;
		grid-template-columns: minmax(160px, 0.35fr) minmax(0, 1fr);
		gap: clamp(24px, 5vw, 72px);
		padding: 28px 0;
		border-bottom: 1px solid var(--line);
	}

	h3 {
		margin: 0;
		color: var(--ink);
		font-size: 20px;
		line-height: 1.1;
		font-weight: 720;
		letter-spacing: -0.01em;
	}

	p {
		max-width: 780px;
		margin: 0;
		color: var(--muted);
		font-size: 18px;
		line-height: 1.45;
	}

	@media (max-width: 820px) {
		.row {
			grid-template-columns: 1fr;
		}
	}
</style>
