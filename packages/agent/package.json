{
	"name": "@southbag/code-core",
	"version": "0.80.4",
	"description": "Southbag Code core agent runtime",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./node": {
			"types": "./dist/node.d.ts",
			"import": "./dist/node.js"
		},
		"./package.json": "./package.json"
	},
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"clean": "shx rm -rf dist",
		"build": "tsgo -p tsconfig.build.json",
		"prepublishOnly": "npm run clean && npm run build"
	},
	"dependencies": {
		"@southbag/code-ai": "^0.80.4",
		"ignore": "7.0.5",
		"typebox": "1.1.38",
		"yaml": "2.9.0"
	},
	"keywords": [
		"ai",
		"agent",
		"llm",
		"transport",
		"state-management"
	],
	"author": "Mario Zechner",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/SouthbagHQ/code",
		"directory": "packages/agent"
	},
	"engines": {
		"node": ">=22.19.0"
	},
	"devDependencies": {
		"@types/node": "24.12.4",
		"typescript": "5.9.3"
	}
}
