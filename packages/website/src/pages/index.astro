---
import CodeBlock from "../components/CodeBlock.astro";
import ContentSection from "../components/ContentSection.astro";
import InfoRows from "../components/InfoRows.astro";

const commands = "npm i -g @southbag/code\nsouthbag-code";
const whyRows = [
	{
		title: "Project aware",
		body: "Loads local instruction files, settings, themes, skills, and extensions when the project is trusted."
	},
	{
		title: "Session native",
		body: "Continue, resume, fork, clone, compact, import, export, and inspect work without losing the path."
	},
	{
		title: "Plain about trust",
		body: "No fake sandbox promise. It runs as your user; isolation belongs in containers, VMs, or policy sandboxes."
	}
];

const workflowRows = [
	{
		title: "Start",
		body: "Run Southbag Code in the project directory and give it the task in plain language."
	},
	{
		title: "Steer",
		body: "Queue follow-ups while the agent works, reference files with @, and run shell commands inline."
	},
	{
		title: "Return",
		body: "Resume recent sessions, branch from earlier points, or export a session when the work needs to travel."
	}
];
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>Southbag Code</title>
	</head>
	<body>
		<div class="shell">
			<main>
				<section class="hero">
					<div class="hero-copy">
						<h1>
							Write code only slightly slower than <span class="accent">Kevin</span>
						</h1>
						<CodeBlock code={commands} />
					</div>
				</section>

				<ContentSection
					id="why"
					title="Small surface. Serious workflow."
					description="Southbag Code keeps the interface close to the place developers already work: the terminal."
				>
					<InfoRows rows={whyRows} />
				</ContentSection>

				<ContentSection
					id="workflow"
					title="Install, start, keep context."
					description="The main flow is intentionally direct: open a repo, start the agent, steer the work, and review the diff."
				>
					<InfoRows rows={workflowRows} />
				</ContentSection>

				<ContentSection
					id="install"
					title="Bring the agent to the repo."
					description="Install globally, open a project, and run the CLI from the working directory."
					variant="closing"
				>
					<CodeBlock code={commands} />
				</ContentSection>
			</main>
		</div>
	</body>
</html>

<style>
	:root {
		--bg: #060606;
		--panel: #0f0f0f;
		--panel-2: #171717;
		--ink: #f2f2f2;
		--muted: #b0b0b0;
		--quiet: #747474;
		--line: rgba(242, 242, 242, 0.12);
		--line-strong: rgba(242, 242, 242, 0.24);
		--lime: #c7f36b;
		--max: 1180px;
	}

	* {
		box-sizing: border-box;
	}

	html {
		scroll-behavior: smooth;
	}

	body {
		margin: 0;
		min-width: 320px;
		color: var(--ink);
		background:
			radial-gradient(circle at 72% 18%, rgba(255, 255, 255, 0.09), transparent 28%),
			radial-gradient(circle at 18% 86%, rgba(255, 255, 255, 0.055), transparent 30%),
			linear-gradient(135deg, #0a0a0a, var(--bg) 54%, #020202);
		font-family: "Avenir Next", "Helvetica Neue", Helvetica, Arial, sans-serif;
		letter-spacing: 0;
	}

	body::before {
		position: fixed;
		inset: 0;
		pointer-events: none;
		content: "";
		background:
			linear-gradient(rgba(255, 255, 255, 0.035) 1px, transparent 1px) 0 0 / 100% 48px,
			linear-gradient(90deg, rgba(255, 255, 255, 0.025) 1px, transparent 1px) 0 0 / 48px 100%;
		mask-image: linear-gradient(to bottom, rgba(0, 0, 0, 0.9), transparent 78%);
	}

	.shell {
		position: relative;
		min-height: 100vh;
		overflow: hidden;
	}

	main {
		position: relative;
		z-index: 1;
	}

	.hero {
		width: min(var(--max), calc(100% - 40px));
		min-height: 100vh;
		margin: 0 auto;
		display: grid;
		align-items: center;
		padding: clamp(72px, 11vw, 142px) 0 clamp(48px, 8vw, 96px);
	}

	.hero-copy {
		max-width: 1040px;
	}

	h1 {
		margin: 0;
		max-width: 1060px;
		font-size: clamp(54px, 10vw, 138px);
		line-height: 0.92;
		font-weight: 760;
		letter-spacing: -0.045em;
	}

	.accent {
		color: var(--lime);
	}

	@media (max-width: 820px) {
		.hero {
			min-height: auto;
		}
	}

	@media (max-width: 520px) {
		.hero {
			width: min(100% - 28px, var(--max));
		}

		h1 {
			font-size: clamp(46px, 16vw, 72px);
		}
	}
</style>
